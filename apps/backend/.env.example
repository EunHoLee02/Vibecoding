APP_NAME=well-track-backend
APP_ENV=dev
APP_DEBUG=false
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BACKEND_PUBLIC_BASE_URL=http://localhost:8000
LOCAL_STORAGE_DIR=.storage

DATABASE_URL=postgresql+psycopg://welltrack:change-me@localhost:5432/welltrack
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_POOL_PRE_PING=true

REDIS_URL=redis://localhost:6379/0
AUTH_REDIS_PREFIX=auth:session

AUTH_SESSION_COOKIE_NAME=sid
AUTH_SESSION_TTL_MINUTES=10080
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_HTTPONLY=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128

MAIL_MODE=logger
OCR_ENGINE=paddleocr
OCR_LANG_LIST=ko,en

# Optional production object storage
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
