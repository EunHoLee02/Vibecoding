COMPOSE_PROJECT_NAME=welltrack

# Shared environment
APP_ENV=dev
APP_DEBUG=false
BACKEND_PUBLIC_BASE_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOCAL_STORAGE_DIR=.storage

# Backend auth/session
AUTH_SESSION_COOKIE_NAME=sid
AUTH_SESSION_TTL_MINUTES=10080
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_HTTPONLY=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_REDIS_PREFIX=auth:session

# Backend mail/OCR
MAIL_MODE=logger
OCR_ENGINE=paddleocr
OCR_LANG_LIST=ko,en

# Database / Redis
POSTGRES_DB=welltrack
POSTGRES_USER=welltrack
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
REDIS_PORT=6379
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_POOL_PRE_PING=true

# Frontend runtime
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
API_BASE_URL=http://backend:8000
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Optional production object storage target
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Optional domains
APP_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:8000
